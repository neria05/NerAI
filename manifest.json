{
  "manifest_version": 3,
  "name": "NerAI - עוזר AI לוואטסאפ",
  "version": "1.1.0",
  "description": "תרגום הודעות בזמן אמת, תרגום תוך כדי הקלדה וניתוח שיחות AI לוואטסאפ ווב | by Ner Online - neronline.co.il",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.whatsapp.com/*",
    "*://translate.googleapis.com/*",
    "*://api.deepseek.com/*",
    "*://api.openai.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "images/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.whatsapp.com/*"],
      "js": [
        "api-services.js",
        "input-translate.js",
        "content.js",
        "quick-chat.js",
        "fix-translation-service.js"
      ]
    }
  ],
  "icons": {
    "128": "images/icon.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
